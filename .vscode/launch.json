{
  "version": "0.2.0",
  "inputs": [
    {
      "id": "unreviewedDataDir",
      "type": "promptString",
      "description": "Data directory for unreviewed transaction exports",
      "default": "data"
    },
    {
      "id": "unreviewedFilename",
      "type": "promptString",
      "description": "Base filename for unreviewed transaction exports",
      "default": "unreviewed_transactions"
    },
    {
      "id": "categoryGroupsOutput",
      "type": "promptString",
      "description": "Output CSV path for category group export",
      "default": "data/category_groups.csv"
    },
    {
      "id": "accountGroupsOutput",
      "type": "promptString",
      "description": "Output CSV path for account group export",
      "default": "data/account_groups.csv"
    },
    {
      "id": "groupNetReportOutput",
      "type": "promptString",
      "description": "Output CSV path for group net-by-year report",
      "default": "data/group_net_by_year_report.csv"
    },
    {
      "id": "yearlyPivotSource",
      "type": "promptString",
      "description": "Source CSV path for yearly amount pivots",
      "default": "data/all_transactions.csv"
    },
    {
      "id": "yearlyPivotOutput",
      "type": "promptString",
      "description": "Output Excel path for yearly amount pivots",
      "default": "data/yearly_amount_pivots.xlsx"
    },
    {
      "id": "tagReportSource",
      "type": "promptString",
      "description": "Source CSV path for tag activity report",
      "default": "data/all_transactions.csv"
    },
    {
      "id": "tagReportOutput",
      "type": "promptString",
      "description": "Output Excel path for tag activity report",
      "default": "data/tag_activity.xlsx"
    },
    {
      "id": "tagReportLookbackYears",
      "type": "promptString",
      "description": "Calendar years to include in tag activity report",
      "default": "3"
    },
    {
      "id": "yearlyPivotYears",
      "type": "promptString",
      "description": "Year columns: auto or comma-separated years",
      "default": "auto"
    },
    {
      "id": "yearlyPivotExcludeGroups",
      "type": "promptString",
      "description": "Groups to exclude from yearly pivots, comma-separated",
      "default": ""
    },
    {
      "id": "yearlyPivotExcludeCategories",
      "type": "promptString",
      "description": "Categories to exclude from yearly pivots, comma-separated",
      "default": ""
    },
    {
      "id": "recurringOptimizationSource",
      "type": "promptString",
      "description": "Source CSV path for recurring optimization",
      "default": "data/all_transactions.csv"
    },
    {
      "id": "recurringOptimizationOutput",
      "type": "promptString",
      "description": "Output Excel path for recurring optimization",
      "default": "data/recurring_optimization.xlsx"
    },
    {
      "id": "recurringOptimizationLookbackMonths",
      "type": "promptString",
      "description": "Months to inspect, capped at 36",
      "default": "36"
    },
    {
      "id": "recurringOptimizationRecentMonths",
      "type": "promptString",
      "description": "Recent months for recency-weighted scoring",
      "default": "6"
    },
    {
      "id": "recurringOptimizationOptimizableType",
      "type": "pickString",
      "description": "Analyze selected category groups or wildcard category terms?",
      "options": [
        "groups",
        "categories"
      ],
      "default": "groups"
    },
    {
      "id": "unreviewedPivotOutput",
      "type": "promptString",
      "description": "Output Excel path for the unreviewed pivot report",
      "default": "data/unreviewed_pivots.xlsx"
    },
    {
      "id": "unreviewedPivotTransactions",
      "type": "promptString",
      "description": "Source CSV path for pending/unreviewed pivot report",
      "default": "data/unreviewed_transactions.csv"
    },
    {
      "id": "unreviewedPivotAccountGroups",
      "type": "promptString",
      "description": "Account metadata CSV path for pending/unreviewed pivot report",
      "default": "data/account_groups.csv"
    },
    {
      "id": "copyTransactionIds",
      "type": "promptString",
      "description": "Transaction IDs to copy into push.csv (space, comma, semicolon, or newline separated)",
      "default": ""
    },
    {
      "id": "filterKind",
      "type": "pickString",
      "description": "Filter transactions by accounts, merchants, categories, groups, all files, or merchant/account files?",
      "options": [
        "merchants",
        "accounts",
        "categories",
        "groups",
        "all",
        "both"
      ],
      "default": "merchants"
    },
    {
      "id": "filterOutput",
      "type": "promptString",
      "description": "Output CSV path for filtered rows. Filenames like push3 become data/push3.csv",
      "default": "data/push.csv"
    },
    {
      "id": "filterWriteMode",
      "type": "pickString",
      "description": "Append to the output file or overwrite it?",
      "options": [
        "overwrite",
        "append"
      ],
      "default": "overwrite"
    },
    {
      "id": "filterUnreviewedSource",
      "type": "promptString",
      "description": "Source CSV path for unreviewed filtering",
      "default": "data/unreviewed_transactions.csv"
    },
    {
      "id": "filterUnreviewedMerchantFile",
      "type": "promptString",
      "description": "Merchant filter file for unreviewed filtering",
      "default": "data/filter-unrev-merchants.txt"
    },
    {
      "id": "filterUnreviewedAccountFile",
      "type": "promptString",
      "description": "Account filter file for unreviewed filtering",
      "default": "data/filter-unrev-accounts.txt"
    },
    {
      "id": "filterUnreviewedCategoryFile",
      "type": "promptString",
      "description": "Category filter file for unreviewed filtering",
      "default": "data/filter-unrev-categories.txt"
    },
    {
      "id": "filterUnreviewedGroupFile",
      "type": "promptString",
      "description": "Group filter file for unreviewed filtering",
      "default": "data/filter-unrev-groups.txt"
    },
    {
      "id": "filterCategoryGroupsFile",
      "type": "promptString",
      "description": "Category group CSV path for group filtering",
      "default": "data/category_groups.csv"
    },
    {
      "id": "pushInputFile",
      "type": "promptString",
      "description": "Push input CSV or JSON file",
      "default": "data/push.csv"
    },
    {
      "id": "businessReportGroups",
      "type": "promptString",
      "description": "Comma-separated group search terms to include",
      "default": "Immanent"
    },
    {
      "id": "businessReportExcludeGroups",
      "type": "promptString",
      "description": "Optional comma-separated group search terms to exclude",
      "default": ""
    },
    {
      "id": "businessReportYear",
      "type": "promptString",
      "description": "Fiscal year for the business report",
      "default": "2026"
    }
  ],
  "configurations": [
    {
      "name": "Auth - Login",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/login.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Pull - Categories and Tags",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/pull_cats_tags.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Pull - Category Groups",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/pull_category_groups.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--output",
        "${input:categoryGroupsOutput}"
      ]
    },
    {
      "name": "Pull - Account Groups",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/pull_account_groups.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--output",
        "${input:accountGroupsOutput}"
      ]
    },
    {
      "name": "Pull - Transactions and Unreviewed",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/pull_transactions_persist_batches.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Pull - Unreviewed Only",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/get_unreviewed.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--data-dir",
        "${input:unreviewedDataDir}",
        "--filename",
        "${input:unreviewedFilename}"
      ]
    },
    {
      "name": "Review - Unreviewed Pivot Report",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/report_unreviewed_pivots.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--transactions",
        "${input:unreviewedPivotTransactions}",
        "--account-groups",
        "${input:unreviewedPivotAccountGroups}",
        "--output",
        "${input:unreviewedPivotOutput}"
      ]
    },
    {
      "name": "Review - Filter Unreviewed Merchants To Push",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/filter_unreviewed_to_push.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--filter-type",
        "merchants",
        "--unreviewed",
        "${input:filterUnreviewedSource}",
        "--merchant-filter",
        "${input:filterUnreviewedMerchantFile}",
        "--output",
        "${input:filterOutput}",
        "--write-mode",
        "${input:filterWriteMode}"
      ]
    },
    {
      "name": "Review - Filter Unreviewed Accounts To Push",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/filter_unreviewed_to_push.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--filter-type",
        "accounts",
        "--unreviewed",
        "${input:filterUnreviewedSource}",
        "--account-filter",
        "${input:filterUnreviewedAccountFile}",
        "--output",
        "${input:filterOutput}",
        "--write-mode",
        "${input:filterWriteMode}"
      ]
    },
    {
      "name": "Review - Filter Unreviewed Categories To Push",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/filter_unreviewed_to_push.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--filter-type",
        "categories",
        "--unreviewed",
        "${input:filterUnreviewedSource}",
        "--category-filter",
        "${input:filterUnreviewedCategoryFile}",
        "--output",
        "${input:filterOutput}",
        "--write-mode",
        "${input:filterWriteMode}"
      ]
    },
    {
      "name": "Review - Filter Unreviewed Groups To Push",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/filter_unreviewed_to_push.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--filter-type",
        "groups",
        "--unreviewed",
        "${input:filterUnreviewedSource}",
        "--group-filter",
        "${input:filterUnreviewedGroupFile}",
        "--groups",
        "${input:filterCategoryGroupsFile}",
        "--output",
        "${input:filterOutput}",
        "--write-mode",
        "${input:filterWriteMode}"
      ]
    },
    {
      "name": "Review - Filter Unreviewed Merchant/Account To Push",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/filter_unreviewed_to_push.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--filter-type",
        "both",
        "--unreviewed",
        "${input:filterUnreviewedSource}",
        "--merchant-filter",
        "${input:filterUnreviewedMerchantFile}",
        "--account-filter",
        "${input:filterUnreviewedAccountFile}",
        "--output",
        "${input:filterOutput}",
        "--write-mode",
        "${input:filterWriteMode}"
      ]
    },
    {
      "name": "Review - Filter Unreviewed All To Push",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/filter_unreviewed_to_push.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--filter-type",
        "all",
        "--unreviewed",
        "${input:filterUnreviewedSource}",
        "--merchant-filter",
        "${input:filterUnreviewedMerchantFile}",
        "--account-filter",
        "${input:filterUnreviewedAccountFile}",
        "--category-filter",
        "${input:filterUnreviewedCategoryFile}",
        "--group-filter",
        "${input:filterUnreviewedGroupFile}",
        "--groups",
        "${input:filterCategoryGroupsFile}",
        "--output",
        "${input:filterOutput}",
        "--write-mode",
        "${input:filterWriteMode}"
      ]
    },
    {
      "name": "Review - Filter All To Push",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/filter_all_to_push.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--filter-type",
        "${input:filterKind}",
        "--output",
        "${input:filterOutput}",
        "--write-mode",
        "${input:filterWriteMode}"
      ]
    },
    {
      "name": "Review - Copy Transaction IDs To Push",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/copy_transaction_ids_to_push.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--transaction-ids",
        "${input:copyTransactionIds}"
      ]
    },
    {
      "name": "Push - Dry Run",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/push.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--data-dir",
        "data",
        "--input-file",
        "${input:pushInputFile}",
        "--dry-run",
        "true"
      ]
    },
    {
      "name": "Push - Live + Update Local",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/push.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--data-dir",
        "data",
        "--input-file",
        "${input:pushInputFile}",
        "--dry-run",
        "false",
        "--update-local",
        "true",
        "--all-transactions",
        "data/all_transactions.csv",
        "--unreviewed-file",
        "data/unreviewed_transactions.csv"
      ]
    },
    {
      "name": "Push - Post-Failure Local Update",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/push.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--data-dir",
        "data",
        "--input-file",
        "${input:pushInputFile}",
        "--local-only",
        "true",
        "--all-transactions",
        "data/all_transactions.csv",
        "--unreviewed-file",
        "data/unreviewed_transactions.csv"
      ]
    },
    {
      "name": "Reports - Group Net By Year CSV (Legacy)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/report_group_net_by_year.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--output",
        "${input:groupNetReportOutput}"
      ]
    },
    {
      "name": "Reports - Yearly Amount Pivots",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/report_yearly_amount_pivots.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--transactions",
        "${input:yearlyPivotSource}",
        "--years",
        "${input:yearlyPivotYears}",
        "--exclude-groups",
        "${input:yearlyPivotExcludeGroups}",
        "--exclude-categories",
        "${input:yearlyPivotExcludeCategories}",
        "--output",
        "${input:yearlyPivotOutput}"
      ]
    },
    {
      "name": "Reports - Tag Activity",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/report_tag_activity.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--transactions",
        "${input:tagReportSource}",
        "--lookback-years",
        "${input:tagReportLookbackYears}",
        "--output",
        "${input:tagReportOutput}"
      ]
    },
    {
      "name": "Reports - Recurring Optimization",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/report_recurring_optimization.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--transactions",
        "${input:recurringOptimizationSource}",
        "--lookback-months",
        "${input:recurringOptimizationLookbackMonths}",
        "--recent-months",
        "${input:recurringOptimizationRecentMonths}",
        "--optimizable-type",
        "${input:recurringOptimizationOptimizableType}",
        "--output",
        "${input:recurringOptimizationOutput}"
      ]
    },
    {
      "name": "Reports - Business",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/business_report.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--group-terms",
        "${input:businessReportGroups}",
        "--exclude-group-terms",
        "${input:businessReportExcludeGroups}",
        "--fiscal-year",
        "${input:businessReportYear}"
      ]
    },
    {
      "name": "Tools - Current File With Arguments",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": "${command:pickArgs}"
    }
  ]
}
