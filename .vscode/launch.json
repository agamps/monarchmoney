{
  "version": "0.2.0",
  "inputs": [
    {
      "id": "pushDataDir",
      "type": "promptString",
      "description": "Data directory for categories.json and tags.json",
      "default": "data"
    },
    {
      "id": "pushInputFile",
      "type": "promptString",
      "description": "Push input CSV or JSON file",
      "default": "push.csv"
    },
    {
      "id": "pushDryRun",
      "type": "promptString",
      "description": "Dry run mode (true or false)",
      "default": "TRUE"
    },
    {
      "id": "unreviewedDataDir",
      "type": "promptString",
      "description": "Data directory for unreviewed transaction exports",
      "default": "data"
    },
    {
      "id": "unreviewedFilename",
      "type": "promptString",
      "description": "Base filename for unreviewed transaction exports",
      "default": "unreviewed_only_transactions"
    },
    {
      "id": "categoryGroupsOutput",
      "type": "promptString",
      "description": "Output CSV path for category group export",
      "default": "data/category_groups.csv"
    },
    {
      "id": "groupNetReportOutput",
      "type": "promptString",
      "description": "Output CSV path for group net-by-year report",
      "default": "data/group_net_by_year_report.csv"
    },
    {
      "id": "copyTransactionIds",
      "type": "promptString",
      "description": "Transaction IDs to copy into push.csv (space, comma, semicolon, or newline separated)",
      "default": ""
    },
    {
      "id": "businessReportYear",
      "type": "promptString",
      "description": "Fiscal year for the business report",
      "default": "2026"
    },
    {
      "id": "businessReportBusiness",
      "type": "promptString",
      "description": "Business for the report (immanent or virtus)",
      "default": "immanent"
    },
    {
      "id": "businessReportOutput",
      "type": "promptString",
      "description": "Output Excel path for the business report",
      "default": "data/immanent_business_report_2026.xlsx"
    }
  ],
  "configurations": [
    {
      "name": "Python Debugger: Pull cats and tags into data folder",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/pull_cats_tags.py",
      "console": "integratedTerminal",
      "args": "${command:pickArgs}"
    },
    {
      "name": "Python Debugger: Login",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/login.py",
      "console": "integratedTerminal",
      "args": "${command:pickArgs}"
    },
    {
      "name": "Python Debugger: Current File with Arguments",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "args": "${command:pickArgs}"
    },
    {
      "name": "Python Debugger: Push",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/push.py",
      "console": "integratedTerminal",
      "args": [
        "--data-dir",
        "${input:pushDataDir}",
        "--input-file",
        "${input:pushInputFile}",
        "--dry-run",
        "${input:pushDryRun}"
      ]
    },
    {
      "name": "Python Debugger: Pull transactions and persist batches",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/pull_transactions_persist_batches.py",
      "console": "integratedTerminal",
      "args": "${command:pickArgs}"
    },
    {
      "name": "Python Debugger: Pull category groups",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/pull_category_groups.py",
      "console": "integratedTerminal",
      "args": [
        "--output",
        "${input:categoryGroupsOutput}"
      ]
    },
    {
      "name": "Python Debugger: Group net by year report",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/report_group_net_by_year.py",
      "console": "integratedTerminal",
      "args": [
        "--output",
        "${input:groupNetReportOutput}"
      ]
    },
    {
      "name": "Python Debugger: Copy transactions to push",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/copy_transactions_to_push.py",
      "console": "integratedTerminal",
      "args": [
        "--transaction-ids",
        "${input:copyTransactionIds}"
      ]
    },
    {
      "name": "Python Debugger: Business report",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/business_report.py",
      "console": "integratedTerminal",
      "args": [
        "--fiscal-year",
        "${input:businessReportYear}",
        "--business",
        "${input:businessReportBusiness}",
        "--output",
        "${input:businessReportOutput}"
      ]
    },
    {
      "name": "Python Debugger: Get unreviewed",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/get_unreviewed.py",
      "console": "integratedTerminal",
      "args": [
        "--data-dir",
        "${input:unreviewedDataDir}",
        "--filename",
        "${input:unreviewedFilename}"
      ]
    },

    // -------------------------------------------------------
    // PUSH: dry run, no local file update
    // -------------------------------------------------------
    {
      "name": "Push — DRY RUN",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/push.py",
      "console": "integratedTerminal",
      "args": [
        "--data-dir",   "data",
        "--input-file", "data/push.csv",
        "--dry-run",    "true"
      ]
    },

    // -------------------------------------------------------
    // PUSH: LIVE, no local file update
    // -------------------------------------------------------
    {
      "name": "Push — 🚨 LIVE",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/push.py",
      "console": "integratedTerminal",
      "args": [
        "--data-dir",   "data",
        "--input-file", "data/push.csv",
        "--dry-run",    "false"
      ]
    },

    // -------------------------------------------------------
    // PUSH + UPDATE LOCAL: LIVE, patches local CSVs after push
    // -------------------------------------------------------
    {
      "name": "Push — 🚨 LIVE + Update Local",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/push.py",
      "console": "integratedTerminal",
      "args": [
        "--data-dir",         "data",
        "--input-file",       "data/push.csv",
        "--dry-run",          "false",
        "--update-local",     "true",
        "--all-transactions", "data/all_transactions.csv",
        "--unreviewed-file",  "data/unreviewed_transactions.csv"
      ]
    },

    // -------------------------------------------------------
    // PULL CATEGORY GROUPS: export to data folder
    // -------------------------------------------------------
    {
      "name": "Pull Category Groups",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/pull_category_groups.py",
      "console": "integratedTerminal",
      "args": [
        "--output", "data/category_groups.csv"
      ]
    },

    // -------------------------------------------------------
    // GROUP NET REPORT: export to data folder
    // -------------------------------------------------------
    {
      "name": "Group Net By Year Report",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/report_group_net_by_year.py",
      "console": "integratedTerminal",
      "args": [
        "--output", "data/group_net_by_year_report.csv"
      ]
    },

    // -------------------------------------------------------
    // COPY TRANSACTIONS: select rows into push.csv
    // -------------------------------------------------------
    {
      "name": "Copy Transactions To Push",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/copy_transactions_to_push.py",
      "console": "integratedTerminal",
      "args": "${command:pickArgs}"
    },

    // -------------------------------------------------------
    // BUSINESS REPORT: export Excel workbook
    // -------------------------------------------------------
    {
      "name": "Business Report",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/business_report.py",
      "console": "integratedTerminal",
      "args": [
        "--fiscal-year",
        "${input:businessReportYear}",
        "--business",
        "${input:businessReportBusiness}",
        "--output",
        "${input:businessReportOutput}"
      ]
    },
    {
      "name": "Business Report - Immanent 2026",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/business_report.py",
      "console": "integratedTerminal",
      "args": [
        "--fiscal-year", "2026",
        "--business", "immanent",
        "--output", "data/immanent_business_report_2026.xlsx"
      ]
    }
  ]
}
