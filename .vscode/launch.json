{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "inputs": [
    {
      "id": "pushDataDir",
      "type": "promptString",
      "description": "Data directory for categories.json and tags.json",
      "default": "data"
    },
    {
      "id": "pushInputFile",
      "type": "promptString",
      "description": "Push input CSV or JSON file",
      "default": "push.csv"
    },
    {
      "id": "pushDryRun",
      "type": "promptString",
      "description": "Dry run mode (true or false)",
      "default": "TRUE"
    }
  ],
  "configurations": [
    {
      "name": "Python Debugger: Pull cats and tags into data folder",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/pull_cats_tags.py",
      "console": "integratedTerminal",
      "args": "${command:pickArgs}"
    },
    {
      "name": "Python Debugger: Login",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/login.py",
      "console": "integratedTerminal",
      "args": "${command:pickArgs}"
    },
    {
      "name": "Python Debugger: Current File with Arguments",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "args": "${command:pickArgs}"
    },
    {
      "name": "Python Debugger: Push",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/push.py",
      "console": "integratedTerminal",
      "args": [
        "--data-dir",
        "${input:pushDataDir}",
        "--input-file",
        "${input:pushInputFile}",
        "--dry-run",
        "${input:pushDryRun}"
      ]
    },
    {
      "name": "Python Debugger: Pull transactions and persist batches",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/pull_transactions_persist_batches.py",
      "console": "integratedTerminal",
      "args": "${command:pickArgs}"
    },
  ]
}
